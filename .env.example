# ═══════════════════════════════════════════════════════════
# AttendTrack — Root Environment Variables Template
# Copy the relevant section to backend/.env and frontend/.env
# See backend/.env.example and frontend/.env.example for details.
# ═══════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ─────────────────────────
# Transaction pooler URL from: Settings → Database → Connection String → Transaction
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Redis (Render / Upstash) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Enterprise Auth ─────────────────────────────────────────
DEFAULT_ADMIN_PASSWORD=ChangeMe@First
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ── JWT ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_64_char_random_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Matrix COSEC Biometric API ───────────────────────────────
MATRIX_COSEC_BASE_URL=https://cosec.yourcompany.com/cosec
MATRIX_COSEC_USERNAME=SA
MATRIX_COSEC_PASSWORD=your_cosec_appliance_password

# ── Biometric Sync Scheduler ─────────────────────────────────
BIOMETRIC_SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=15
LIVE_CACHE_TTL_MINUTES=15

# ── Frontend URL (CORS) ───────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Deployment ───────────────────────────────────────────────
PORT=8000
DEMO_MODE=false

# ── Docker Compose (local only) ──────────────────────────────
POSTGRES_USER=attendance_admin
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=attendance_db

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_BASE_URL=https://your-backend.onrender.com
