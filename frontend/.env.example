# ═══════════════════════════════════════════════════════════
# frontend/.env.example — Frontend Environment Variables
# Copy this file to frontend/.env and fill in your values.
# NEVER commit frontend/.env to version control.
# ═══════════════════════════════════════════════════════════

# ── API Base URL ─────────────────────────────────────────────
# Production: Your Render backend URL (no trailing slash)
# Example:    https://attendtrack-api.onrender.com
#
# Local dev:  Leave blank — Vite proxy routes /auth, /attendance,
#             /hierarchy, /admin to http://localhost:8000 automatically.
VITE_API_BASE_URL=https://your-backend.onrender.com
