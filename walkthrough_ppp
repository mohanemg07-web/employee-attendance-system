"""
Async SQLAlchemy engine, session factory, and FastAPI dependency.
Supports PostgreSQL (production) and SQLite (local dev/testing).
"""
import os
from sqlalchemy.ext.asyncio import AsyncSession, create_async_engine, async_sessionmaker
from sqlalchemy.orm import DeclarativeBase

from app.config import get_settings

settings = get_settings()

# Determine database URL — fall back to SQLite if Postgres is unreachable
_db_url = settings.DATABASE_URL
_is_sqlite = False

if "postgresql" in _db_url:
    # Check if we should use SQLite fallback (for local dev without Docker)
    _use_sqlite = os.environ.get("USE_SQLITE", "").lower() in ("1", "true", "yes")
    if _use_sqlite:
        _db_url = "sqlite+aiosqlite:///./attendance_dev.db"
        _is_sqlite = True

if _is_sqlite:
    engine = create_async_engine(_db_url, echo=False)
else:
    engine = create_async_engine(
        _db_url,
        echo=False,
        pool_size=20,
        max_overflow=10,
        pool_pre_ping=True,
    )

AsyncSessionLocal = async_sessionmaker(
    bind=engine,
    class_=AsyncSession,
    expire_on_commit=False,
)


class Base(DeclarativeBase):
    """Declarative base for all ORM models."""
    pass


async def init_db():
    """Create all tables (used for SQLite dev mode)."""
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)


async def get_db() -> AsyncSession:
    """FastAPI dependency that yields an async DB session."""
    async with AsyncSessionLocal() as session:
        try:
            yield session
            await session.commit()
        except Exception:
            await session.rollback()
            raise
        finally:
            await session.close()
