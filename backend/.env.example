# ═══════════════════════════════════════════════════════════
# backend/.env.example — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
# Production: Use Supabase Transaction pooler (port 6543)
# Dashboard → Project Settings → Database → Connection String → Transaction
# Format: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Local dev: Leave blank — app falls back to SQLite (attendance_dev.db)
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Redis ────────────────────────────────────────────────────
# Used for dashboard caching and Celery task broker.
# Render: auto-populated via render.yaml fromService binding.
# Upstash (free tier): rediss://default:TOKEN@HOST.upstash.io:6379
# Local dev: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Enterprise Authentication ─────────────────────────────────
# Default password issued to employees on account creation / admin reset.
# Employees are forced to change this on first login.
DEFAULT_ADMIN_PASSWORD=ChangeMe@First

# Brute-force protection settings
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# Render auto-generates this when you use generateValue: true in render.yaml
JWT_SECRET_KEY=CHANGE_ME_generate_a_64_char_random_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Matrix COSEC Biometric API ───────────────────────────────
# The base URL of your organization's COSEC appliance.
# Leave blank to disable biometric sync (app runs in CSV-only mode).
MATRIX_COSEC_BASE_URL=https://cosec.yourcompany.com/cosec
MATRIX_COSEC_USERNAME=SA
MATRIX_COSEC_PASSWORD=your_cosec_appliance_password

# ── Biometric Sync Scheduler ─────────────────────────────────
# Set to true to enable the in-process APScheduler background sync.
# Only enable when MATRIX_COSEC_BASE_URL is configured.
BIOMETRIC_SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=15

# ── Caching ──────────────────────────────────────────────────
# TTL for Redis live-attendance cache (minutes)
LIVE_CACHE_TTL_MINUTES=15

# ── Frontend URL (CORS) ───────────────────────────────────────
# Production: Your Vercel deployment URL.
# Local dev: http://localhost:5173
FRONTEND_URL=https://your-app.vercel.app

# ── Deployment ───────────────────────────────────────────────
PORT=8000
DEMO_MODE=false
